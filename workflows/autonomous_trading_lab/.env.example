# Nexus Autonomous Trading Lab — Environment
# These are already set in ~/nexus-ai/.env (symlinked as .env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=<anon key — read access>
SUPABASE_SERVICE_ROLE_KEY=<service role key — write access>

NEXUS_LLM_BASE_URL=https://openrouter.ai/api/v1
NEXUS_LLM_API_KEY=<token>
NEXUS_LLM_MODEL=meta-llama/llama-3.3-70b-instruct

TELEGRAM_BOT_TOKEN=<bot token>
TELEGRAM_CHAT_ID=<chat id>

MAX_SIGNALS_PER_RUN=5
SPREAD_THRESHOLD=0.0003
POLL_INTERVAL_SECONDS=60
