# Nexus AI Trading Analyst — Environment
# Copy to .env and fill in values (already present in ~/nexus-ai/.env)

# Supabase — anon key for reads, service_role for proposal writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Preferred AI gateway
NEXUS_LLM_BASE_URL=https://openrouter.ai/api/v1
NEXUS_LLM_API_KEY=<your token>
NEXUS_LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Telegram alerts
TELEGRAM_BOT_TOKEN=<bot token>
TELEGRAM_CHAT_ID=<chat id>

# Polling interval in seconds (poll mode only)
POLL_INTERVAL_SECONDS=60
