<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.raymonddavis.nexus.control-center</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>

    <key>Nice</key>
    <integer>5</integer>

    <key>WorkingDirectory</key>
    <string>/Users/raymonddavis/nexus-ai</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/raymonddavis/nexus-ai &amp;&amp; exec /usr/local/bin/python3 control_center/control_center_server.py --host 127.0.0.1 --port 4000</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/raymonddavis/nexus-ai/openclaw/logs/control-center.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/raymonddavis/nexus-ai/openclaw/logs/control-center.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/raymonddavis</string>
        <key>PATH</key>
        <string>/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>15</integer>
</dict>
</plist>
