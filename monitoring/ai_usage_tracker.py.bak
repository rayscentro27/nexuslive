"""
AI Usage Tracker.

Records each OpenClaw / AI API call into ai_usage_log for cost and
latency monitoring.

Usage:
    from monitoring.ai_usage_tracker import track_ai_call, timed_ai_call
    import time, urllib.request

    t0 = time.time()
    # ... make your OpenClaw request ...
    latency = int((time.time() - t0) * 1000)

    track_ai_call(
        caller='signal_reviewer',
        prompt_chars=len(prompt),
        response_chars=len(response),
        latency_ms=latency,
    )

Or use the context manager:
    with timed_ai_call('signal_reviewer', prompt) as ctx:
        response = call_openclaw(prompt)
        ctx.response = response
"""

import os
import json
import time
import logging
import urllib.request
import urllib.error
from typing import Optional

logger = logging.getLogger('AIUsageTracker')

SUPABASE_URL = os.getenv('SUPABASE_URL', '')
SUPABASE_KEY = os.getenv('SUPABASE_KEY', '')

# Rough cost model: ~$0.002 per 1000 chars total (OpenClaw/GPT-4o estimate)
_COST_PER_1K_CHARS = float(os.getenv('AI_COST_PER_1K_CHARS', '0.002'))


def _headers() -> dict:
    key = os.getenv('SUPABASE_KEY', SUPABASE_KEY)
    return {
        'apikey':        key,
        'Authorization': f'Bearer {key}',
        'Content-Type':  'application/json',
        'Prefer':        'return=minimal',
    }


def estimate_cost(prompt_chars: int, response_chars: int) -> float:
    total = (prompt_chars + response_chars) / 1000.0
    return round(total * _COST_PER_1K_CHARS, 6)


def track_ai_call(
    caller: str,
    prompt_chars: int       = 0,
    response_chars: int     = 0,
    latency_ms: int         = 0,
    model: str              = 'openclaw',
    status: str             = 'ok',
    cost_usd: Optional[float] = None,
    meta: Optional[dict]    = None,
) -> bool:
    """Insert one ai_usage_log row. Fire-and-forget — never raises."""
    if cost_usd is None:
        cost_usd = estimate_cost(prompt_chars, response_chars)

    url  = f"{os.getenv('SUPABASE_URL', SUPABASE_URL)}/rest/v1/ai_usage_log"
    row  = {
        'caller':         caller,
        'model':          model,
        'prompt_chars':   prompt_chars,
        'response_chars': response_chars,
        'latency_ms':     latency_ms,
        'cost_usd':       cost_usd,
        'status':         status,
        'meta':           meta or {},
    }
    data = json.dumps(row).encode()
    req  = urllib.request.Request(url, data=data, headers=_headers(), method='POST')
    try:
        with urllib.request.urlopen(req, timeout=6) as _:
            return True
    except Exception:
        return False


class timed_ai_call:
    """
    Context manager that automatically records timing and cost.

    with timed_ai_call('signal_reviewer', prompt_text) as ctx:
        raw_response = call_openclaw(prompt_text)
        ctx.response = raw_response   # optional — sets response_chars

    ctx.response is '' by default if not set before exit.
    """

    def __init__(self, caller: str, prompt: str = '', model: str = 'openclaw'):
        self.caller       = caller
        self.prompt       = prompt
        self.model        = model
        self.response     = ''
        self._start       = 0.0
        self._status      = 'ok'

    def __enter__(self):
        self._start = time.time()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        latency = int((time.time() - self._start) * 1000)
        status  = 'error' if exc_type else 'ok'
        track_ai_call(
            caller=self.caller,
            prompt_chars=len(self.prompt),
            response_chars=len(self.response),
            latency_ms=latency,
            model=self.model,
            status=status,
        )
        return False   # do not suppress exceptions
