# ─────────────────────────────────────────────────────────────────────────────
# nexus-strategy-lab — Mac Mini worker environment
# Copy to .env (symlink or copy ~/nexus-ai/.env works too)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (shared durable state) ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Hermes AI gateway ─────────────────────────────────────────────────────────
HERMES_GATEWAY_URL=http://localhost:8642
HERMES_GATEWAY_TOKEN=your-hermes-token

# ── OpenClaw AI gateway ───────────────────────────────────────────────────────
OPENCLAW_URL=http://localhost:18789
OPENCLAW_AUTH_TOKEN=your-openclaw-token

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Demo trading account ──────────────────────────────────────────────────────
DEMO_ACCOUNT_ID=             # UUID from demo_accounts table; auto-created if blank
DEMO_STARTING_BALANCE=10000.00
DRY_RUN=true                 # Keep true until 24h monitoring pass complete

# ── Research ingestion ────────────────────────────────────────────────────────
RESEARCH_OUTPUT_DIR=/Users/raymonddavis/nexus-ai/research-engine/summaries
STRATEGIES_DIR=/Users/raymonddavis/nexus-ai/research-engine/strategies

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
LOG_DIR=/Users/raymonddavis/nexus-ai/nexus-strategy-lab/logs
