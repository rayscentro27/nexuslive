            print("    No strategy performance data yet — run backtest to populate")

        print(f"\n  Recent paper trades: {len(paper_trades)}")
        print(f"\n  Safety: REAL_MONEY_TRADING=false | LIVE_TRADING=false")
        print(f"  Run: python3 bin/nexus trading report for live data")
    except Exception as exc:
        print(f"  ⚠️  {exc}")


