# Loaded automatically from ~/nexus-ai/.env — override here if needed
WORKER_ID=nexus-research-worker
POLL_INTERVAL_MS=5000
JOB_LEASE_SECONDS=120
HEARTBEAT_INTERVAL_MS=30000
MAX_JOB_ATTEMPTS=3

# Set to true to enable Hermes AI refinement of research output
ENABLE_HERMES_REFINEMENT=false
OPENCLAW_URL=http://localhost:18789
OPENCLAW_AUTH_TOKEN=your-token
