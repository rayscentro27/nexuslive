# OANDA Practice Account Credentials
# Copy this file to .env and fill in your practice account details.
# .env is gitignored and must NEVER be committed.

# Enable demo adapter (false by default — requires Ray approval to set true)
OANDA_DEMO_ENABLED=false

# Always practice. NEVER set to live.
OANDA_ENVIRONMENT=practice

# Must remain false. Adapter will refuse to run if set to true.
OANDA_ALLOW_LIVE=false

# Your OANDA practice account ID (numeric string)
OANDA_ACCOUNT_ID=

# Your OANDA practice API access token
# NEVER log, print, or commit this value.
OANDA_ACCESS_TOKEN=

# Safety limits
OANDA_MAX_UNITS=1
OANDA_MAX_DAILY_ORDERS=3
