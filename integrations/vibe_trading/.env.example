# Nexus Vibe-Trading Integration — Environment Example
# Copy to .env and fill in any values needed
# NEVER commit a real .env file

# ── Feature flag ──────────────────────────────────────────────────────────────
NEXUS_VIBE_TRADING_ENABLED=false
NEXUS_VIBE_TRADING_MODE=local_cli

# ── Workspace paths ──────────────────────────────────────────────────────────
NEXUS_VIBE_TRADING_WORKSPACE=./integrations/vibe_trading/workspace
NEXUS_VIBE_TRADING_REPORTS=./integrations/vibe_trading/reports

# ── Safety controls (DO NOT change to 1 without explicit approval) ────────────
VIBE_TRADING_ENABLE_SHELL_TOOLS=0
VIBE_TRADING_ALLOWED_FILE_ROOTS=./integrations/vibe_trading/workspace,./integrations/vibe_trading/reports
VIBE_TRADING_ALLOWED_RUN_ROOTS=./integrations/vibe_trading/workspace,./integrations/vibe_trading/reports

# ── API mode (only if running vibe-trading as API server — optional) ──────────
# API_AUTH_KEY=replace-with-strong-local-token
# VIBE_TRADING_API_PORT=18800
# VIBE_TRADING_API_HOST=127.0.0.1

# ── Cost controls ─────────────────────────────────────────────────────────────
NEXUS_ALLOW_PAID_LLM=false
NEXUS_ALLOW_PAID_MARKET_DATA=false
NEXUS_REQUIRE_HUMAN_APPROVAL_FOR_PAID_TOOLS=true

# ── LLM backend (required by Vibe-Trading) ───────────────────────────────────
# Option A — OpenRouter (cheapest: deepseek-chat ~$0.001/run)
# LANGCHAIN_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-key-here
# LANGCHAIN_MODEL_NAME=deepseek/deepseek-chat
#
# Option B — Hermes/Ollama local (free)
# LANGCHAIN_PROVIDER=openai
# OPENAI_BASE_URL=http://localhost:8642/v1
# OPENAI_API_KEY=your-hermes-key
# LANGCHAIN_MODEL_NAME=mistral
